                        <div class="referral-row">
                            <input id="referral-code" class="referral-input" type="text" placeholder="Enter code"
                                maxlength="32" minlength="5" autocomplete="off" oninput="clearReferralState()" />
                            <button class="referral-apply" onclick="applyReferralCode()" type="button">Apply</button>
                        </div>
                        <span class="referral-applied" id="referral-applied">âœ“ Code applied</span>
                        <span class="referral-invalid" id="referral-invalid">âœ— Invalid code</span>
                    </div>
                </div>
                <a id="m-wa" href="#" target="_blank" rel="noopener noreferrer" class="btn-gold enquiry-btn"
                    style="width:100%;margin-top:12px">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                        <path
                            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                    </svg>
                    Enquire on WhatsApp
                </a>
            </div>
        </div>
    </div>
</div>

<!-- POSTER MODAL -->
<div id="poster-overlay" onclick="closePosterModal()">
    <img loading="lazy" id="poster-modal-img" src="" alt="LUVZ Collection promotional poster" loading="lazy"
        decoding="async" />
    <button onclick="event.stopPropagation();closePosterModal()"
        style="position:absolute;top:16px;right:16px;background:rgba(0,0,0,.6);border:1px solid var(--border-h);color:var(--gold);width:33px;height:33px;border-radius:50%;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center">âœ•</button>
</div>

<!-- MOBILE MENU OVERLAY -->
<div id="mob-menu" role="dialog" aria-modal="true" aria-label="Navigation menu">
    <div
        style="display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;padding-bottom:20px;border-bottom:1px solid var(--border-h)">
        <span
            style="font-family:'Cinzel',serif;font-size:.58rem;letter-spacing:.5em;text-transform:uppercase;color:var(--gold);opacity:.65">Menu</span>
        <button onclick="toggleMenu()" aria-label="Close menu"
            style="background:none;border:1px solid var(--border);color:var(--gold);width:34px;height:34px;border-radius:50%;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .2s"
            onmouseenter="this.style.borderColor='var(--gold)'"
            onmouseleave="this.style.borderColor='var(--border)'">âœ•</button>
    </div>
    <a href="#collections" onclick="toggleMenu()" class="mob-link">Collections</a>
    <a href="#featured" onclick="toggleMenu()" class="mob-link">Featured</a>
    <a href="#testimonials" onclick="toggleMenu()" class="mob-link">Reviews</a>
    <a href="#story" onclick="toggleMenu()" class="mob-link">Our Story</a>
    <a href="#contact" onclick="toggleMenu()" class="mob-link">Contact</a>
</div>

<script defer src="app.js"></script>
<footer class="mini-footer" style="padding-bottom:max(40px,calc(70px + env(safe-area-inset-bottom)))">
    <p>Â© 2026 LUVZ Collection</p>
    <a id="admin-link" href="/admin/" class="admin-hidden">Admin Login</a>
</footer>

<script>
    window.addEventListener('keydown', (e) => {
        if (e.ctrlKey && e.altKey && e.key === 'l') {
            document.getElementById('admin-link').classList.toggle('hidden');
        }
    });
</script>

<!-- Floating AI Chat Trigger -->
<button id="luvz-chat-trigger" aria-label="Chat with Luvz Style Assistant">
    <svg class="luvz-trigger-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 1l2.5 7.5H22l-6.5 4.7 2.5 7.5L12 16.2 6 20.7l2.5-7.5L2 8.5h7.5z" />
    </svg>
    <span class="luvz-trigger-label">Ask AI <span>âœ¦</span></span>
    <span class="luvz-dot" aria-hidden="true"></span>
</button>

<!-- Chat Popup -->
<div id="luvz-chat-popup" role="dialog" aria-modal="true" aria-label="Luvz Style Assistant">
    <div class="luvz-chat-header">
        <div class="luvz-chat-avatar" aria-hidden="true">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 1l2.5 7.5H22l-6.5 4.7 2.5 7.5L12 16.2 6 20.7l2.5-7.5L2 8.5h7.5z" />
            </svg>
        </div>
        <div class="luvz-chat-header-text">
            <h3>Luvz Style Assistant</h3>
            <p>Jewellery Advisor Â· Online</p>
        </div>
        <div class="luvz-online-dot" aria-hidden="true"></div>
        <button class="luvz-close-btn" aria-label="Close chat">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path
                    d="M18.3 5.71a1 1 0 00-1.41 0L12 10.59 7.11 5.7A1 1 0 005.7 7.11L10.59 12 5.7 16.89a1 1 0 001.41 1.41L12 13.41l4.89 4.89a1 1 0 001.41-1.41L13.41 12l4.89-4.89a1 1 0 000-1.4z" />
            </svg>
        </button>
    </div>

    <div class="luvz-chat-messages" id="luvz-messages" role="log" aria-live="polite"></div>

    <div class="luvz-suggestions" id="luvz-suggestions" aria-label="Quick questions">
        <button class="luvz-chip" data-msg="Show me gold jhumkas under â‚¹500">Gold Jhumkas</button>
        <button class="luvz-chip" data-msg="What bridal sets do you have?">Bridal Sets</button>
        <button class="luvz-chip" data-msg="Do you offer free shipping?">Shipping Info</button>
        <button class="luvz-chip" data-msg="Show me your trending pieces">Trending Now</button>
    </div>

    <div class="luvz-chat-input-area">
        <textarea id="luvz-chat-input" placeholder="Ask about our jewelleryâ€¦" rows="1" aria-label="Your message"
            autocomplete="off" autocorrect="on" spellcheck="true"></textarea>
        <button id="luvz-chat-send" aria-label="Send message">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
            </svg>
        </button>
    </div>
</div>

<script src="/luvz-chat.js"></script>
</body>
</html>