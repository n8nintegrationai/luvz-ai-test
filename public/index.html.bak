<!-- 2. BRAND STORY â€” Why 92.5 Silver? -->
<section id="story" class="sec reveal">
    <div
        style="max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:120px; align-items:center">
        <!-- LEFT COLUMN: TEXT -->
        <div>
            <div class="eyebrow">Heritage & Craft</div>
            <h2 class="sec-title gold-text" style="margin-bottom:20px">Why 92.5 Silver?</h2>
